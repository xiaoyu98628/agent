# 项目名称
APP_NAME=agent
# 项目环境
APP_ENV=local
# 是否开启调试
APP_DEBUG=true
# 项目端口
APP_PORT=8000
# 部署模式：personal（本地个人）| server（线上服务）
APP_DEPLOYMENT_MODE=personal
# 服务编码（三位数字，必须唯一）
APP_SERVICE_CODE=001

# ---------- LLM（智谱 GLM 示例）----------
LLM_PROVIDER=zhipu
LLM_MODEL=glm-4-flash
# 任选其一填写你的 GLM / 智谱 / Z.ai Key
ZHIPUAI_API_KEY=
# GLM_API_KEY=
# ZAI_API_KEY=
# LLM_API_KEY=

# DeepSeek（OpenAI 兼容）
# DEEPSEEK_API_KEY=
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# 国内 open.bigmodel.cn 用户取消下行注释；国际 Z.ai 默认无需设置
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

LLM_TEMPERATURE=0.7
# LLM_ALLOWED_PROVIDERS=["zhipu","openai","openrouter","anthropic","ollama","deepseek"]
LLM_ALLOW_MODEL_OVERRIDE=true

# ---------- Storage ----------
STORAGE_SQLITE_PATH=agent.sqlite
STORAGE_DEFAULT_WORKSPACE_ID=local

# ---------- Agent ----------
AGENT_MAX_ITERATIONS=25
AGENT_DEFAULT_TOOL_POLICY=full
# AGENT_ENABLED_TOOLSETS=["file","web"]
# AGENT_DISABLED_TOOLSETS=["terminal"]
AGENT_SANDBOX_BACKEND=none
# AGENT_WORKSPACE_SUBDIR=workspace
# AGENT_COMMAND_TIMEOUT_SECONDS=30
# 危险终端命令策略：block（默认阻断）| allow（personal 模式自行承担风险）
# AGENT_DANGEROUS_COMMAND_POLICY=block
# AGENT_WEB_FETCH_TIMEOUT_SECONDS=15
# AGENT_CONTEXT_FILES_ENABLED=true
# AGENT_MAX_CONTEXT_FILE_CHARS=20000
# AGENT_MAX_HISTORY_MESSAGES=200
# AGENT_SUMMARIZATION_ENABLED=true
# AGENT_SUMMARIZATION_TRIGGER_MESSAGES=40
# AGENT_SUMMARIZATION_KEEP_MESSAGES=20
# AGENT_SUMMARIZATION_TRIGGER_TOKENS=12000
# AGENT_SUMMARIZATION_TRIGGER_FRACTION=0.7
# AGENT_SUMMARIZATION_PROVIDER=zhipu
# AGENT_SUMMARIZATION_MODEL=glm-4-flash

# ---------- Gateway (Telegram) ----------
# uv sync --extra gateway
# GATEWAY_TELEGRAM_ENABLED=true
# GATEWAY_TELEGRAM_BOT_TOKEN=
# GATEWAY_TELEGRAM_ALLOWED_CHAT_IDS=[123456789]
# GATEWAY_TELEGRAM_STREAM_REPLIES=true

# ---------- RAG ----------
RAG_ENABLED=true
RAG_VECTOR_BACKEND=sqlite
RAG_EMBEDDING_PROVIDER=zhipu
RAG_EMBEDDING_MODEL=embedding-3
RAG_EMBEDDING_DIMENSIONS=1024
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
RAG_DEFAULT_KNOWLEDGE_BASE_NAME=default

# ---------- Memory ----------
MEMORY_ENABLED=true
MEMORY_USER_PROFILE_ENABLED=true
# MEMORY_CHAR_LIMIT=2200
# MEMORY_USER_CHAR_LIMIT=1375

# ---------- Skills ----------
SKILLS_ENABLED=true
# SKILLS_SUBDIR=skills

# ---------- 日志 ----------
LOG_LEVEL=DEBUG
LOG_DRIVER=single
LOG_JSON=false
LOG_CONSOLE_ENABLED=true
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ---------- 跨域 ----------
CORS_ALLOW_ORIGINS=["*"]
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=600
