# 项目名称
APP_NAME=agent
# 项目环境
APP_ENV=local
# 是否开启调试
APP_DEBUG=true
# 项目端口
APP_PORT=8000
# 部署模式：personal（本地个人）| server（线上服务）
APP_DEPLOYMENT_MODE=personal
# 服务编码（三位数字，必须唯一）
APP_SERVICE_CODE=001

# 模型运行参数
MODEL_TEMPERATURE=0.7
MODEL_ALLOW_OVERRIDE=true
# 可选：指定供应商配置目录；不设置时写入各 provider 包内
# MODEL_PROVIDERS_CONFIG_DIR=storage/model-providers
# 当前默认 provider/model 的薄配置文件
MODEL_ACTIVE_CONFIG_FILE=model_active.json

# 可选：运行时临时覆盖配置文件中的默认供应商 / 默认模型
# MODEL_PROVIDER=openai
# MODEL_NAME=gpt-4.1
