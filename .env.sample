# 项目名称
APP_NAME=agent
# 项目环境
APP_ENV=local
# 是否开启调试
APP_DEBUG=true
# 项目端口
APP_PORT=8000
# 服务编码（三位数字，必须唯一）
APP_SERVICE_CODE=001

# ---------- 日志 ----------
# 级别：DEBUG/INFO/WARNING/ERROR/CRITICAL（默认 INFO）
LOG_LEVEL=DEBUG
LOG_DRIVER=single
LOG_JSON=false
LOG_CONSOLE_ENABLED=true
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ---------- 跨域 ----------
# 列表可用 JSON，如 CORS_ALLOW_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_ORIGINS=["*"]
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=600

# ---------- 数据库 ----------
# 默认连接名（对应 config/database.py connections 中的 key）
DB_CONNECTION=mysql

DB_ECHO="${APP_DEBUG}"
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# mysql 连接
DB_MYSQL_HOST=127.0.0.1
DB_MYSQL_PORT=3306
DB_MYSQL_DATABASE=agent
DB_MYSQL_USERNAME=root
DB_MYSQL_PASSWORD=root
DB_MYSQL_CHARSET=utf8mb4
DB_MYSQL_PREFIX=m_

# pgsql 连接
DB_PGSQL_HOST=127.0.0.1
DB_PGSQL_PORT=5432
DB_PGSQL_DATABASE=agent
DB_PGSQL_USERNAME=postgres
DB_PGSQL_PASSWORD=postgres
DB_PGSQL_PREFIX=m_

# sqlite 连接
DB_SQLITE_DATABASE=database/database.sqlite
